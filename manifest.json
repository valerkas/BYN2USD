{
  "manifest_version": 3,
  "name": "BYN to USD (NBRB)",
  "version": "1.0.1",
  "description": "Показывает эквивалент цен в USD по курсу НБРБ рядом с ценами в BYN.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.nbrb.by/*",
    "https://av.by/*",
    "https://*.av.by/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://av.by/*",
        "https://*.av.by/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "BYN to USD"
  }
}
